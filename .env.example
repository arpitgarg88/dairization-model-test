# Copy this file to .env and fill in your values:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (Linux/macOS)
#
# NEVER commit .env to git.

# Hugging Face token (local models: pyannote + NVIDIA Sortformer)
# Create at: https://huggingface.co/settings/tokens
# Also accept model terms for:
#   pyannote/segmentation-3.0, speaker-diarization-3.1, speaker-diarization-community-1
#   nvidia/diar_sortformer_4spk-v1
#   nvidia/diar_streaming_sortformer_4spk-v2, nvidia/diar_streaming_sortformer_4spk-v2.1
HF_TOKEN=your_huggingface_token_here

# pyannoteAI API key (precision-2 cloud model only)
# Create at: https://dashboard.pyannote.ai/
PYANNOTEAI_API_KEY=your_pyannoteai_api_key_here
